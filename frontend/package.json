    "@types/react-datepicker": "^7.0.0",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.1",
    "cra-template-typescript": "1.3.0",
    "lucide-react": "^1.17.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-data-table-component": "^8.3.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-hot-toast": "^2.6.0",
    "react-modal": "^3.16.3",
    "react-router-dom": "^7.16.0",
    "react-scripts": "5.0.1",
    "react-select": "^5.10.2",
    "recharts": "^2.15.4",
    "tailwindcss": "^3.4.19",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --watchAll=false --testMatch='**/tests/**/*.test.{ts,tsx}'",
    "test:watch": "react-scripts test --testMatch='**/tests/**/*.test.{ts,tsx}'",
    "test:coverage": "react-scripts test --watchAll=false --coverage --testMatch='**/tests/**/*.test.{ts,tsx}'",
    "eject": "react-scripts eject"
  },
  "jest": {
    "testMatch": ["<rootDir>/tests/**/*.test.{ts,tsx}"],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/styleMock.js"
    },
    "setupFilesAfterFramework": ["@testing-library/jest-dom"]
  },
  "eslintConfig": {
    "extends": ["react-app", "react-app/jest"]
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  },
  "proxy": "http://localhost:8015",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^4.9.5",
    "web-vitals": "^5.3.0"
  }
